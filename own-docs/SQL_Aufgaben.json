          }
        }
      },
      "tasks": [
        {
          "id": "sql_customers_by_zip",
          "type": "sql",
          "title": "Customers in postal code range",
          "description": "List all customers whose postal code is between '50800' and '51999'. Show customer ID, company, street, postal code, city, and customer number.",
          "points": 4,
          "maxAttempts": 3,
          "timeLimitSeconds": 300,
          "groupingTags": ["select", "where", "between"],
          "evaluation": {
            "type": "sql",
            "expectedResultSet": [
              [3, "Traberstübchen", "Traberweg 1", "50889", "Cologne", "012205"],
