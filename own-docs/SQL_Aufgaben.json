        {
          "id": "sql_wine_stats_by_vintage",
          "type": "sql",
          "title": "Wine price statistics by vintage",
          "description": "For each vintage year that appears in the products table, show the vintage, the lowest price, the highest price, and the number of wines of that vintage. Order by vintage ascending.",
          "points": 5,
          "maxAttempts": 3,
          "timeLimitSeconds": 600,
          "groupingTags": ["select", "group-by", "aggregation"],
          "evaluation": {
            "type": "sql",
            "expectedResultSet": [
