            ],
            "allowedStatements": ["SELECT"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "INSERT", "CREATE", "GRANT", "ALTER"]
          }
        },
        {
          "id": "sql_fix_red_wine_discount",
          "type": "sql",
          "title": "Correct discount for red wines",
          "description": "For all red wines (wine_type_id = 2) that were invoiced in May 2023, the discount was mistakenly set to 0% instead of 12%. Update the discount_percent in invoice_items to 12.00 for these items.",
          "points": 8,
          "maxAttempts": 3,
          "timeLimitSeconds": 600,
          "groupingTags": ["update", "join"],
          "evaluation": {
            "type": "sql",
            "validationQuery": "SELECT discount_percent FROM invoice_items JOIN invoices ON invoice_items.inv_id = invoices.inv_id JOIN products ON invoice_items.prod_id = products.prod_id WHERE products.wine_type_id = 2 AND strftime('%Y-%m', invoices.invoice_date) = '2023-05'",
            "expectedResult": [[12.00]],
            "allowedStatements": ["UPDATE"],
            "forbiddenStatements": ["DROP", "DELETE", "INSERT", "CREATE", "GRANT", "ALTER"]
          }
        }
