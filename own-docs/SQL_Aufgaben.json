              [2, "Red wine"],
              [3, "Rosé"],
              [4, "Sparkling wine"]
            ],
            "products": [
              [1, "GB-12555", "Grauburgunder", 15.20, "Bottle", 19.00, 2005, 1],
              [2, "GB-12556", "Grauburgunder", 13.10, "Bottle", 19.00, 2006, 1],
              [3, "GB-12558", "Grauburgunder", 11.25, "Bottle", 19.00, 2008, 1],
