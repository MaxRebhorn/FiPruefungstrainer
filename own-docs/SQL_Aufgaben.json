              [55543, 2223, 2, 2, 12.0, 17.20, 0.00, 19.0],
              [55543, 2223, 3, 3, 6.0, 11.25, 5.00, 19.0],
              [55543, 2223, 4, 4, 12.0, 16.40, 5.00, 19.0],
              [55544, 2224, 1, 1, 8.0, 13.80, 0.00, 19.0],
