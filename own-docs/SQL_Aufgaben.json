{
  "version": "1.0",
  "scenarios": [
    {
      "id": "healthcare_db_001",
      "title": "Hospital Medication Management",
      "description": "A database for managing prescriptions, patients, doctors, and medications in a clinical environment.",
      "source": "General database exercise",
      "difficulty": 2,
      "tags": ["sql", "dml", "ddl", "aggregation"],
      "initialState": {
        "database": {
          "dialect": "sqlite",
          "schema": [
            {
              "table": "patients",
              "columns": [
                { "name": "patient_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "first_name", "type": "TEXT" },
                { "name": "last_name", "type": "TEXT" }
              ]
            },
            {
              "table": "doctors",
              "columns": [
                { "name": "doctor_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "first_name", "type": "TEXT" },
                { "name": "last_name", "type": "TEXT" },
                { "name": "specialty", "type": "TEXT" },
                { "name": "email", "type": "TEXT" }
              ]
            },
            {
              "table": "medications",
              "columns": [
                { "name": "med_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "name", "type": "TEXT" }
              ]
            },
            {
              "table": "prescriptions",
              "columns": [
                { "name": "presc_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "patient_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "doctor_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "med_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "dosage", "type": "TEXT" },
                { "name": "instruction", "type": "TEXT" },
                { "name": "prescription_date", "type": "TIMESTAMP" }
              ]
            }
          ],
          "initialData": {
            "patients": [
              [1, "Paul", "Keller"],
              [2, "Julia", "Fischer"],
              [3, "Markus", "Schulz"],
              [4, "Laura", "Weber"],
              [5, "Stefan", "Meyer"],
              [6, "Nina", "Richter"],
              [7, "Felix", "Wagner"]
            ],
            "doctors": [
              [1, "Thomas", "Krueger", "General Medicine", "t.krueger@clinic.de"],
              [2, "Juergen", "Walter", "Cardiology", "j.walter@clinic.de"],
              [3, "Birgit", "Schneider", "Neurology", null],
              [4, "Ralf", "Neumann", "Orthopedics", "r.neumann@clinic.de"]
            ],
            "medications": [
              [1, "Irodon"],
              [2, "Paraneutral"],
              [3, "Aronilin"],
              [4, "Mecasyn"],
              [5, "Algronalin"],
              [6, "Limazynol"]
            ],
            "prescriptions": [
              [1, 1, 4, 1, "200 mg", "2x daily after meals", "2024-05-31 10:00:00"],
              [2, 2, 3, 2, "500 mg", "1x daily", "2024-06-01 14:30:00"],
              [3, 1, 2, 3, "250 mg", "3x daily for 7 days", "2024-06-02 09:00:00"],
              [4, 4, 3, 4, "500 mg", "1x daily in the morning", "2024-06-03 11:00:00"],
              [5, 6, 2, 6, "20 mg", "1x daily in the morning", "2024-06-05 16:30:00"],
              [6, 1, 3, 1, "200 mg", "2x daily after meals", "2024-06-07 10:00:00"],
              [7, 2, 1, 2, "500 mg", "1x daily", "2024-06-08 14:30:00"],
              [8, 2, 3, 4, "500 mg", "1x daily in the morning", "2024-05-20 11:00:00"],
              [9, 6, 1, 6, "20 mg", "1x daily in the morning", "2024-05-22 16:30:00"],
              [10, 1, 3, 1, "200 mg", "2x daily after meals", "2024-05-24 10:00:00"],
              [11, 2, 4, 2, "500 mg", "1x daily", "2024-05-25 14:30:00"],
              [12, 3, 2, 3, "250 mg", "3x daily for 7 days", "2024-05-26 09:00:00"],
              [13, 6, 1, 6, "20 mg", "1x daily in the morning", "2024-05-29 16:30:00"]
            ]
          }
        }
      },
      "tasks": [
        {
          "id": "sql_doctor_insert",
          "type": "sql",
          "title": "Insert a new doctor",
          "description": "Insert a new doctor with the following details: first name 'Hugo', last name 'Horner', specialty 'General Medicine'. Use NULL for email.",
          "points": 3,
          "maxAttempts": 2,
          "timeLimitSeconds": 300,
          "groupingTags": ["insert", "dml"],
          "evaluation": {
            "type": "sql",
            "expectedEffect": {
              "table": "doctors",
              "shouldContain": [
                { "first_name": "Hugo", "last_name": "Horner", "specialty": "General Medicine", "email": null }
              ]
            },
            "allowedStatements": ["INSERT"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "CREATE", "GRANT", "ALTER"]
          }
        },
        {
          "id": "sql_grant_permission",
          "type": "sql",
          "title": "Grant write permissions",
          "description": "Grant INSERT and UPDATE privileges on the 'prescriptions' table to user 'hhorner'.",
          "points": 3,
          "maxAttempts": 2,
          "timeLimitSeconds": 300,
          "groupingTags": ["grant", "permissions"],
          "evaluation": {
            "type": "sql",
            "expectedEffect": {
              "privileges": [
                { "user": "hhorner", "table": "prescriptions", "rights": ["INSERT", "UPDATE"] }
              ]
            },
            "allowedStatements": ["GRANT"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "INSERT", "CREATE", "ALTER"]
          }
        },
        {
          "id": "sql_revoke_permission",
          "type": "sql",
          "title": "Revoke write permissions",
          "description": "Revoke INSERT and UPDATE privileges on the 'prescriptions' table from user 'sklinkel'.",
          "points": 3,
          "maxAttempts": 2,
          "timeLimitSeconds": 300,
          "groupingTags": ["revoke", "permissions"],
          "evaluation": {
            "type": "sql",
            "expectedEffect": {
              "privileges": [
                { "user": "sklinkel", "table": "prescriptions", "rights": ["INSERT", "UPDATE"], "present": false }
              ]
            },
            "allowedStatements": ["REVOKE"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "INSERT", "CREATE", "GRANT", "ALTER"]
          }
        },
        {
          "id": "sql_alter_column_notnull",
          "type": "sql",
          "title": "Make email column required",
          "description": "The 'email' column in the 'doctors' table must become NOT NULL. For existing rows where email is NULL, set the email to 'info@clinic.de' first. Then alter the column to NOT NULL.",
          "points": 5,
          "maxAttempts": 2,
          "timeLimitSeconds": 600,
          "groupingTags": ["update", "alter", "ddl"],
          "evaluation": {
            "type": "sql",
            "validationQuery": "SELECT COUNT(*) FROM doctors WHERE email IS NULL",
            "expectedResult": [[0]],
            "allowedStatements": ["UPDATE", "ALTER"],
            "forbiddenStatements": ["DROP", "DELETE", "INSERT", "CREATE", "GRANT"]
          }
        },
        {
          "id": "sql_prescription_count_per_patient",
          "type": "sql",
          "title": "Patients with at least three prescriptions",
          "description": "List patient ID, last name, first name, and the number of prescriptions for patients who have received at least three prescriptions. Order descending by prescription count.",
          "points": 8,
          "maxAttempts": 3,
          "timeLimitSeconds": 600,
          "groupingTags": ["select", "group-by", "having", "join"],
          "evaluation": {
            "type": "sql",
            "expectedResultSet": [
              [1, "Keller", "Paul", 4],
              [2, "Fischer", "Julia", 4],
              [6, "Richter", "Nina", 3]
            ],
            "allowedStatements": ["SELECT"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "INSERT", "CREATE", "GRANT", "ALTER"]
          }
        },
        {
          "id": "sql_average_prescriptions",
          "type": "sql",
          "title": "Average number of prescriptions per patient",
          "description": "Calculate the average number of prescriptions per patient. The result should be a single value, rounded to one decimal place.",
          "points": 5,
          "maxAttempts": 3,
          "timeLimitSeconds": 300,
          "groupingTags": ["select", "aggregate", "avg"],
          "evaluation": {
            "type": "sql",
            "expectedResultSet": [[2.0]],
            "allowedStatements": ["SELECT"],
            "forbiddenStatements": ["DROP", "DELETE", "UPDATE", "INSERT", "CREATE", "GRANT", "ALTER"]
          }
        }
      ]
    },
    {
      "id": "wine_shop_db_002",
      "title": "Wine Shop Management",
      "description": "A relational database for a wine shop, storing customers, articles, invoices, and invoice line items.",
      "source": "General database exercise",
      "difficulty": 2,
      "tags": ["sql", "joins", "update", "select"],
      "initialState": {
        "database": {
          "dialect": "sqlite",
          "schema": [
            {
              "table": "customers",
              "columns": [
                { "name": "cust_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "company", "type": "TEXT" },
                { "name": "street", "type": "TEXT" },
                { "name": "postal_code", "type": "TEXT" },
                { "name": "city", "type": "TEXT" },
                { "name": "customer_number", "type": "TEXT" }
              ]
            },
            {
              "table": "products",
              "columns": [
                { "name": "prod_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "product_number", "type": "TEXT" },
                { "name": "description", "type": "TEXT" },
                { "name": "price", "type": "REAL" },
                { "name": "unit", "type": "TEXT" },
                { "name": "vat_rate", "type": "REAL" },
                { "name": "vintage", "type": "INTEGER" },
                { "name": "wine_type_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] }
              ]
            },
            {
              "table": "wine_types",
              "columns": [
                { "name": "wine_type_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "type_name", "type": "TEXT" }
              ]
            },
            {
              "table": "invoices",
              "columns": [
                { "name": "inv_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "cust_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "invoice_number", "type": "TEXT" },
                { "name": "invoice_date", "type": "DATE" },
                { "name": "payment_due_days", "type": "INTEGER" }
              ]
            },
            {
              "table": "invoice_items",
              "columns": [
                { "name": "item_id", "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
                { "name": "inv_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "prod_id", "type": "INTEGER", "constraints": ["FOREIGN KEY"] },
                { "name": "line_number", "type": "INTEGER" },
                { "name": "quantity", "type": "REAL" },
                { "name": "unit_price", "type": "REAL" },
                { "name": "discount_percent", "type": "REAL" },
                { "name": "vat_rate", "type": "REAL" }
              ]
            }
          ],
