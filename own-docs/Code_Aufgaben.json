{
  "version": "1.0",
  "scenarios": [
    {
      "id": "resource_util_001",
      "title": "Resource Utilization Analysis",
      "description": "A system tracks resource allocations over time. Implement a function that counts how many days within a given period a specific facility exceeds 80% utilization, based on allocation records.",
      "source": "General programming exercise",
      "difficulty": 3,
      "tags": ["date-handling", "arrays", "percentage", "loops"],
      "initialCode": {
        "entryPoint": "ResourceAnalyzer.calculateOverloadDays",
        "files": [
          {
            "path": "ResourceAnalyzer.js",
            "content": [
              "/**",
              " * Analyzes resource allocations.",
              " * The method calculateOverloadDays must be implemented.",
              " */",
              "class ResourceAnalyzer {",
              "    /**",
              "     * @param {ResourceAllocation[]} allocations - Array of allocation records",
              "     * @param {Date} startDate - Start of analysis period (inclusive)",
              "     * @param {Date} endDate - End of analysis period (inclusive)",
              "     * @param {Facility} facility - The facility to analyze",
              "     * @returns {number} Number of days where utilization > 80%",
              "     */",
              "    calculateOverloadDays(allocations, startDate, endDate, facility) {",
              "        // TODO: Implement logic",
              "        return 0;",
              "    }",
              "}",
              "",
              "class ResourceAllocation {",
              "    constructor(resourceId, startDate, endDate, facilityId) {",
              "        this._resourceId = resourceId;",
              "        this._startDate = startDate;",
              "        this._endDate = endDate;",
              "        this._facilityId = facilityId;",
              "    }",
              "    getResourceId() { return this._resourceId; }",
              "    getStartDate() { return this._startDate; }",
              "    getEndDate() { return this._endDate; }",
              "    getFacilityId() { return this._facilityId; }",
              "}",
              "",
              "class Facility {",
              "    constructor(facilityId, capacity) {",
              "        this._facilityId = facilityId;",
              "        this._capacity = capacity;",
              "    }",
              "    getFacilityId() { return this._facilityId; }",
              "    getCapacity() { return this._capacity; }",
              "}",
              "",
              "module.exports = { ResourceAnalyzer, ResourceAllocation, Facility };"
            ].join("\n")
          },
          {
            "path": "DateHelper.mock.js",
            "content": [
              "// Mock utility for date operations (hidden from user)",
              "class DateHelper {",
              "    static addDays(date, days) {",
              "        const result = new Date(date);",
              "        result.setDate(result.getDate() + days);",
              "        return result;",
              "    }",
              "    static diffDays(start, end) {",
              "        const diff = end.getTime() - start.getTime();",
              "        return Math.ceil(diff / (1000 * 60 * 60 * 24));",
              "    }",
              "}",
              "global.DateHelper = DateHelper;"
            ].join("\n"),
            "hidden": true
          }
        ]
      },
      "tasks": [
        {
          "id": "pseudo_util_01",
          "type": "pseudocode",
          "title": "Implement calculateOverloadDays",
          "description": "Complete the method `calculateOverloadDays`. Given an array of `ResourceAllocation` objects, a date range (`startDate` to `endDate`), and a specific `Facility`, count how many days within that range the facility's utilization exceeded 80%. Utilization = (number of allocated resources on that day) / (facility capacity). Each allocation occupies one resource from `startDate` (inclusive) to `endDate` (exclusive). The end date is not counted as occupied. Use the provided `DateHelper` mock for date calculations.",
          "points": 25,
          "maxAttempts": 3,
          "timeLimitSeconds": 1200,
          "hardcoreMode": false,
          "groupingTags": ["date-iteration", "utilization", "counting"],
          "evaluation": {
            "type": "javascript",
            "testCases": [
              {
                "name": "No allocations",
                "input": {
                  "allocations": [],
                  "startDate": "2025-02-01T00:00:00Z",
                  "endDate": "2025-02-05T00:00:00Z",
                  "facility": { "facilityId": 1, "capacity": 10 }
                },
                "expectedOutput": 0
              },
              {
                "name": "Full utilization exactly 80% – not counted",
                "input": {
                  "allocations": [
                    { "resourceId": 1, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 2, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 3, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 4, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 5, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 6, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 7, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 8, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 }
                  ],
                  "startDate": "2025-02-01T00:00:00Z",
                  "endDate": "2025-02-04T00:00:00Z",
                  "facility": { "facilityId": 1, "capacity": 10 }
                },
                "expectedOutput": 0
              },
              {
                "name": "One day >80%",
                "input": {
                  "allocations": [
                    { "resourceId": 1, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 2, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 3, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 4, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 5, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 6, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 7, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 8, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 },
                    { "resourceId": 9, "startDate": "2025-02-01T00:00:00Z", "endDate": "2025-02-03T00:00:00Z", "facilityId": 1 }
                  ],
                  "startDate": "2025-02-01T00:00:00Z",
                  "endDate": "2025-02-04T00:00:00Z",
                  "facility": { "facilityId": 1, "capacity": 10 }
                },
                "expectedOutput": 2
              }
            ],
            "setupCode": "const { ResourceAnalyzer, ResourceAllocation, Facility } = require('./ResourceAnalyzer'); const analyzer = new ResourceAnalyzer(); const toDate = (s) => new Date(s); const buildAlloc = (arr) => arr.map(a => new ResourceAllocation(a.resourceId, toDate(a.startDate), toDate(a.endDate), a.facilityId)); const buildFacility = (f) => new Facility(f.facilityId, f.capacity);",
            "invocation": "analyzer.calculateOverloadDays(buildAlloc(input.allocations), toDate(input.startDate), toDate(input.endDate), buildFacility(input.facility))",
            "comparator": "deepEqual",
            "mocksInjected": true
          }
        }
      ]
    },
    {
      "id": "route_opt_002",
      "title": "Optimal Waypoint Navigation",
      "description": "A delivery drone must visit a set of waypoints. Starting from the first waypoint, it always flies to the nearest unvisited waypoint. Implement the route calculation algorithm.",
      "source": "General programming exercise",
      "difficulty": 3,
      "tags": ["nearest-neighbor", "arrays", "distance", "greedy"],
      "initialCode": {
        "entryPoint": "RoutePlanner.calculateRoute",
        "files": [
          {
            "path": "RoutePlanner.js",
            "content": [
              "/**",
              " * Plans a route through waypoints using nearest neighbor heuristic.",
              " */",
              "class RoutePlanner {",
              "    /**",
              "     * @param {Waypoint[]} waypoints - Array of waypoints to visit (will be modified)",
              "     * @returns {Waypoint[]} - Ordered array of waypoints representing the flight path",
              "     */",
              "    calculateRoute(waypoints) {",
              "        // The first waypoint is the starting position",
              "        const route = [waypoints[0]];",
              "        let currentPos = waypoints[0];",
              "        // Remove the first element from waypoints",
              "        waypoints.splice(0, 1);",
              "        ",
              "        // TODO: Continue implementation: while waypoints not empty,",
              "        // find nearest, add to route, remove from waypoints, update currentPos",
              "        ",
              "        return route;",
              "    }",
              "}",
              "",
              "class Waypoint {",
              "    constructor(x, y, z) {",
              "        this._x = x;",
              "        this._y = y;",
              "        this._z = z;",
              "    }",
              "    getX() { return this._x; }",
              "    getY() { return this._y; }",
              "    getZ() { return this._z; }",
              "    setX(val) { this._x = val; }",
              "    setY(val) { this._y = val; }",
              "    setZ(val) { this._z = val; }",
              "}",
              "",
              "module.exports = { RoutePlanner, Waypoint };"
            ].join("\n")
          },
          {
            "path": "DistanceCalculator.mock.js",
            "content": [
              "// Mock distance calculator (hidden from user)",
              "class DistanceCalculator {",
              "    static getDistance(p1, p2) {",
              "        const dx = p1.getX() - p2.getX();",
              "        const dy = p1.getY() - p2.getY();",
              "        const dz = p1.getZ() - p2.getZ();",
              "        return Math.sqrt(dx*dx + dy*dy + dz*dz);",
              "    }",
              "}",
              "global.DistanceCalculator = DistanceCalculator;"
            ].join("\n"),
            "hidden": true
          }
        ]
      },
      "tasks": [
        {
          "id": "pseudo_route_01",
          "type": "pseudocode",
          "title": "Implement calculateRoute (nearest neighbor)",
          "description": "Complete the method `calculateRoute` in `RoutePlanner`. The algorithm: Start with the first waypoint as current position and add it to the route. Then repeatedly find the waypoint among the remaining ones that has the smallest distance to the current position (use `DistanceCalculator.getDistance`). Add that waypoint to the route, remove it from the list, and set it as the new current position. Continue until no waypoints remain. Return the route array. You may modify the input array. Use `Number.MAX_VALUE` to initialize minimum distance.",
          "points": 25,
          "maxAttempts": 3,
          "timeLimitSeconds": 900,
          "hardcoreMode": false,
          "groupingTags": ["nearest-neighbor", "greedy", "array-manipulation"],
          "evaluation": {
            "type": "javascript",
            "testCases": [
              {
                "name": "Two points",
                "input": {
                  "waypoints": [
                    { "x": 0, "y": 0, "z": 0 },
                    { "x": 10, "y": 0, "z": 0 }
                  ]
                },
                "expectedOutput": [
                  { "x": 0, "y": 0, "z": 0 },
                  { "x": 10, "y": 0, "z": 0 }
                ]
              },
              {
                "name": "Three points in order",
                "input": {
                  "waypoints": [
                    { "x": 0, "y": 0, "z": 0 },
                    { "x": 5, "y": 0, "z": 0 },
                    { "x": 10, "y": 0, "z": 0 }
                  ]
                },
                "expectedOutput": [
                  { "x": 0, "y": 0, "z": 0 },
                  { "x": 5, "y": 0, "z": 0 },
                  { "x": 10, "y": 0, "z": 0 }
                ]
              },
              {
                "name": "Nearest neighbor selection",
                "input": {
                  "waypoints": [
                    { "x": 0, "y": 0, "z": 0 },
                    { "x": 100, "y": 0, "z": 0 },
                    { "x": 50, "y": 0, "z": 0 }
                  ]
                },
                "expectedOutput": [
                  { "x": 0, "y": 0, "z": 0 },
                  { "x": 50, "y": 0, "z": 0 },
                  { "x": 100, "y": 0, "z": 0 }
                ]
              }
            ],
            "setupCode": "const { RoutePlanner, Waypoint } = require('./RoutePlanner'); const planner = new RoutePlanner(); const toWaypoint = (p) => new Waypoint(p.x, p.y, p.z); const mapInput = (wpList) => wpList.map(w => toWaypoint(w)); const mapOutput = (wpArray) => wpArray.map(wp => ({ x: wp.getX(), y: wp.getY(), z: wp.getZ() }));",
            "invocation": "mapOutput(planner.calculateRoute(mapInput(input.waypoints)))",
            "comparator": "deepEqual",
            "mocksInjected": true
          }
        }
      ]
